{
  "name": "kintone-ui-component",
  "version": "1.24.0",
  "description": "kintone UI Component",
  "author": {
    "name": "Cybozu, Inc.",
    "url": "https://cybozu.co.jp"
  },
  "license": "MIT",
  "engines": {
    "node": ">=24.14.1"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kintone-labs/kintone-ui-component"
  },
  "files": [
    "lib",
    "umd"
  ],
  "main": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "module": "./lib/index.js",
  "unpkg": "./umd/kuc.min.js",
  "keywords": [
    "kintone",
    "kintone-ui-component",
    "ui framework",
    "ui component"
  ],
  "scripts": {
    "build:umd_dev": "node ./scripts/webpack-umd.js development",
    "build:umd_prod": "node ./scripts/webpack-umd.js production",
    "build:esm": "tsc -p tsconfig.esm.json && node ./scripts/webpack-esm.js",
    "build-storybook": "storybook build -o ./docs/storybook/",
    "storybook": "storybook dev",
    "test": "rm -rf ./unit_test && tsc -p tsconfig.test.json && web-test-runner",
    "es-lint": "eslint src",
    "actionlint": "node-actionlint"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.28.6",
    "@cybozu/eslint-config": "^25.0.1",
    "@open-wc/testing": "^4.0.0",
    "@storybook/addon-a11y": "^10.3.5",
    "@storybook/web-components-vite": "^10.3.5",
    "@types/mocha": "^10.0.10",
    "@web/test-runner": "^0.20.2",
    "babel-loader": "^10.1.1",
    "chromatic": "^16.3.0",
    "deepmerge": "^4.3.1",
    "eslint": "^9.39.4",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-kuc-v1": "file:eslint-plugin-kuc-v1",
    "node-actionlint": "^1.2.2",
    "prettier": "^3.8.3",
    "storybook": "^10.3.5",
    "ts-loader": "^9.5.7",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "webpack": "^5.106.2",
    "webpack-cli": "^7.0.2"
  },
  "dependencies": {
    "core-js": "^3.49.0",
    "lit": "^3.3.2",
    "uuid": "^14.0.0"
  }
}
